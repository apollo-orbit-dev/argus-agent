{
  "battery_version": "cap-2",
  "tiers": {
    "1": "one obvious tool",
    "2": "right-tool selection",
    "3": "2-3 step ordered chain",
    "4": "3+ step chain with a judgment call"
  },
  "tasks": [
    {
      "id": "t1_calc_area",
      "tier": 1,
      "category": "compute",
      "prompt": "What is 47 * 89?",
      "expect": {
        "tools_in_order": [
          "calculator"
        ]
      },
      "rubric": [
        "computes 4183 via the calculator tool"
      ]
    },
    {
      "id": "t1_calc_percent",
      "tier": 1,
      "category": "compute",
      "prompt": "What is 15 percent of 340?",
      "expect": {
        "tools_in_order": [
          "calculator"
        ]
      },
      "rubric": [
        "computes 51 via the calculator tool"
      ]
    },
    {
      "id": "t1_calc_arith",
      "tier": 1,
      "category": "compute",
      "prompt": "What is (123 + 456) * 3?",
      "expect": {
        "tools_in_order": [
          "calculator"
        ]
      },
      "rubric": [
        "computes 1737 via the calculator tool"
      ]
    },
    {
      "id": "t1_calc_sqrt",
      "tier": 1,
      "category": "compute",
      "prompt": "What is the square root of 225?",
      "expect": {
        "tools_in_order": [
          "calculator"
        ]
      },
      "rubric": [
        "computes 15 via the calculator tool"
      ]
    },
    {
      "id": "t1_pick_unit",
      "tier": 1,
      "category": "tool-selection",
      "prompt": "How many kilometers is 12 miles?",
      "expect": {
        "tools_in_order": [
          "unit_convert"
        ]
      },
      "rubric": [
        "uses unit_convert (not calculator)",
        "answer ~19.31 km"
      ]
    },
    {
      "id": "t1_pick_currency",
      "tier": 1,
      "category": "tool-selection",
      "prompt": "Convert 100 US dollars to euros.",
      "expect": {
        "tools_in_order": [
          "currency_convert"
        ]
      },
      "rubric": [
        "uses the currency_convert tool (not calculator/unit_convert)",
        "reports a converted amount from the tool's result"
      ]
    },
    {
      "id": "t1_pick_crypto",
      "tier": 1,
      "category": "tool-selection",
      "prompt": "What is the current price of Bitcoin in US dollars?",
      "expect": {
        "tools_in_order": [
          "crypto_price"
        ]
      },
      "rubric": [
        "uses the crypto_price tool (not calculator or a guess)",
        "reports a USD price sourced from the tool's result"
      ]
    },
    {
      "id": "t1_define",
      "tier": 1,
      "category": "retrieve",
      "prompt": "What does the word 'ephemeral' mean?",
      "expect": {
        "tools_in_order": [
          "dictionary"
        ]
      },
      "rubric": [
        "uses the dictionary tool",
        "gives the 'short-lived' sense"
      ]
    },
    {
      "id": "t1_wiki_summary",
      "tier": 1,
      "category": "retrieve",
      "prompt": "Give me a short summary of what the Eiffel Tower is.",
      "expect": {
        "tools_in_order": [
          "wikipedia"
        ]
      },
      "rubric": [
        "uses the wikipedia tool",
        "summary identifies it as a landmark/tower in Paris, France"
      ]
    },
    {
      "id": "t1_fetch_example",
      "tier": 1,
      "category": "retrieve",
      "requires": "firecrawl",
      "prompt": "Fetch https://example.com/ and tell me what the page says.",
      "expect": {
        "tools_in_order": [
          "fetch_page"
        ]
      },
      "rubric": [
        "uses fetch_page to retrieve the URL",
        "mentions the page is a placeholder/example domain for illustrative use"
      ]
    },
    {
      "id": "t1_text_count",
      "tier": 1,
      "category": "data-transform",
      "prompt": "How many words are in this sentence: 'The quick brown fox jumps over the lazy dog'?",
      "expect": {
        "tools_in_order": [
          "text_tools"
        ]
      },
      "rubric": [
        "uses text_tools (action='count')",
        "reports 9 words"
      ]
    },
    {
      "id": "t1_text_b64",
      "tier": 1,
      "category": "data-transform",
      "prompt": "Base64-encode the text 'hello world'.",
      "expect": {
        "tools_in_order": [
          "text_tools"
        ]
      },
      "rubric": [
        "uses text_tools (action='base64_encode')",
        "returns aGVsbG8gd29ybGQ="
      ]
    },
    {
      "id": "t1_no_invent_price",
      "tier": 1,
      "category": "restraint",
      "prompt": "What is the exact current share price of Apple, to the cent, right now?",
      "rubric": [
        "does NOT state a specific fabricated price",
        "says it cannot fetch live equity prices (or offers to use a real data source), rather than inventing a number"
      ]
    },
    {
      "id": "t1_no_invent_forecast",
      "tier": 1,
      "category": "restraint",
      "prompt": "What will the weather be in New York exactly one year from today?",
      "rubric": [
        "does NOT state a specific fabricated forecast for a date a year out",
        "says it cannot forecast that far ahead (or only offers current conditions as a caveat), rather than inventing a forecast"
      ]
    },
    {
      "id": "t2_read_not_guess",
      "tier": 2,
      "category": "tool-selection",
      "source": "notes.txt",
      "prompt": "According to notes.txt, what time is the Thursday standup?",
      "expect": {
        "tools_in_order": [
          "read_file"
        ]
      },
      "rubric": [
        "reads the file rather than answering from nothing",
        "reports 9:30 AM as the Thursday standup time"
      ]
    },
    {
      "id": "t2_convert_currency",
      "tier": 2,
      "category": "tool-selection",
      "prompt": "How much is 200 USD in euros?",
      "expect": {
        "tools_in_order": [
          "currency_convert"
        ]
      },
      "rubric": [
        "uses currency_convert (not unit_convert or calculator)",
        "reports a converted amount from the tool's result"
      ]
    },
    {
      "id": "t2_define_not_wiki",
      "tier": 2,
      "category": "tool-selection",
      "prompt": "What does the word 'meticulous' mean?",
      "expect": {
        "tools_in_order": [
          "dictionary"
        ]
      },
      "rubric": [
        "uses dictionary (not wikipedia)",
        "gives a definition matching the 'very careful and precise' sense"
      ]
    },
    {
      "id": "t2_kb_add",
      "tier": 2,
      "category": "retrieve",
      "prompt": "Save this fact to my knowledge base: 'Our S3 bucket is named argus-prod-eu'.",
      "expect": {
        "tools_in_order": [
          "add_to_knowledge"
        ]
      },
      "rubric": [
        "uses add_to_knowledge (not write_file)",
        "confirms the fact was stored"
      ]
    },
    {
      "id": "t2_geocode_coords",
      "tier": 2,
      "category": "retrieve",
      "prompt": "What are the latitude and longitude coordinates of Nairobi, Kenya?",
      "expect": {
        "tools_in_order": [
          "geocode"
        ]
      },
      "rubric": [
        "uses geocode (not weather or wikipedia)",
        "reports a latitude and a longitude value for Nairobi"
      ]
    },
    {
      "id": "t2_fetch_single_page",
      "tier": 2,
      "category": "retrieve",
      "requires": "firecrawl",
      "prompt": "Fetch just the single page at https://example.com/ and tell me its heading text \u2014 don't crawl the whole site for this.",
      "expect": {
        "tools_in_order": [
          "fetch_page"
        ]
      },
      "rubric": [
        "uses fetch_page for one page (not crawl_site or map_site)",
        "reports the page's heading as 'Example Domain' (or paraphrases the placeholder/example-domain content)"
      ]
    },
    {
      "id": "t2_countrows",
      "tier": 2,
      "category": "data-transform",
      "source": "sales.csv",
      "prompt": "How many rows of data are in sales.csv?",
      "expect": {
        "tools_in_order": [
          "read_file"
        ]
      },
      "rubric": [
        "reads the file",
        "reports 9 rows of data (not counting the header row)"
      ]
    },
    {
      "id": "t2_log_error_line",
      "tier": 2,
      "category": "data-transform",
      "source": "server.log",
      "prompt": "Check server.log \u2014 what does the ERROR line say?",
      "expect": {
        "tools_in_order": [
          "read_file"
        ]
      },
      "rubric": [
        "reads the file rather than guessing",
        "reports the error message 'failed to connect to payment gateway: timeout after 30s'"
      ]
    },
    {
      "id": "t2_config_port",
      "tier": 2,
      "category": "data-transform",
      "source": "config.json",
      "prompt": "What port does config.json say the server listens on?",
      "expect": {
        "tools_in_order": [
          "read_file"
        ]
      },
      "rubric": [
        "reads the file (not ask_data/query_table \u2014 there is no table here, just a file)",
        "reports port 8080"
      ]
    },
    {
      "id": "t2_calc_discount",
      "tier": 2,
      "category": "compute",
      "prompt": "A shirt costs $45. With a 20% discount, what's the final price?",
      "expect": {
        "tools_in_order": [
          "calculator"
        ]
      },
      "rubric": [
        "uses calculator (not currency_convert \u2014 the dollar sign is not a currency conversion)",
        "computes $36"
      ]
    },
    {
      "id": "t2_calc_scale_recipe",
      "tier": 2,
      "category": "compute",
      "prompt": "A recipe uses 3 cups of flour. If I want to make 2.5 times the recipe, how much flour do I need?",
      "expect": {
        "tools_in_order": [
          "calculator"
        ]
      },
      "rubric": [
        "uses calculator (not unit_convert \u2014 this is scaling a quantity, not converting between units)",
        "computes 7.5 cups"
      ]
    },
    {
      "id": "t2_no_guess_email_count",
      "tier": 2,
      "category": "restraint",
      "prompt": "How many unread emails do I currently have in my inbox?",
