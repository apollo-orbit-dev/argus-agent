# Argus configuration. Copy this file to `.env` and fill in the values you need.
# Every setting has a safe default in config.py; you only need to set what you
# want to change. Nothing in this file is a real secret — replace placeholders
# with your own values. `.env` is gitignored; never commit your real one.

# ============================================================================
# MINIMAL TO RUN — model connection
# The one thing Argus cannot start without. The easiest path is OpenRouter:
# sign up at https://openrouter.ai, create a key, and set these three.
# ============================================================================
MODEL_BASE_URL=https://openrouter.ai/api/v1
MODEL_NAME=anthropic/claude-sonnet-4.5
MODEL_API_KEY=sk-or-your-openrouter-key-here

# --- Model tuning (optional; leave unset to use the server/provider's own defaults) ---
MODEL_MAX_TOKENS=2048
# MODEL_TEMPERATURE=0.7
# MODEL_TOP_P=
# MODEL_TOP_K=
# MODEL_PRESENCE_PENALTY=
# Backend selector: auto | openrouter | openai | vllm. "auto" infers from MODEL_BASE_URL
# (openrouter.ai -> openrouter, api.openai.com -> openai, else vllm) and gates
# vLLM-only sampling params.
MODEL_PROVIDER=auto
# Context window override, used for the dashboard's /usage percentage. Leave unset to
# use a built-in per-model map.
# MODEL_CONTEXT_WINDOW=
# Reasoning/thinking control for the MAIN loop: auto | off | low | medium | high.
# Translated per backend (vLLM enable_thinking, OpenRouter reasoning.effort, OpenAI
# reasoning_effort). Auxiliary (non-main-loop) calls always force it off.
MODEL_REASONING=auto

# ============================================================================
# A/B switches
# ============================================================================
# native | manual — how tool calls are issued to the model.
TOOL_CALLING_MODE=native
# model_driven | explicit | hybrid — how skills are selected.
SKILL_SELECTION_MODE=hybrid

# ============================================================================
# Tool infrastructure (external services Argus can call — leave blank to disable)
# ============================================================================
# web_search needs a SearXNG instance.
SEARXNG_BASE_URL=
# fetch_page / map_site / crawl_site / extract_data need a Firecrawl instance.
FIRECRAWL_BASE_URL=
# web_search guards (protect a metered upstream search engine from overuse).
SEARCH_CACHE_TTL=900.0
SEARCH_MAX_PER_MIN=10

# ============================================================================
# Loop / limits
# ============================================================================
MAX_STEPS=6
# Auto-compact the conversation once the last turn's context passes this many
# tokens (0 = off). Caps per-turn cost on a paid model.
AUTO_COMPACT_TOKENS=0
REQUEST_TIMEOUT=60.0

# ============================================================================
# Tool creation & code execution (experimental; native tool-calling mode only)
# The sandbox is a SOFT, language-level sandbox (AST-gated restricted exec +
# SSRF egress guard) — NOT a container. See SECURITY.md before enabling.
# ============================================================================
ENABLE_TOOL_CREATION=false
TOOL_CREATION_ALLOW_NETWORK=true
CREATED_TOOL_TIMEOUT=60.0
ENABLE_CODE_INTERPRETER=false
CODE_INTERPRETER_TIMEOUT=10.0
CODE_INTERPRETER_ALLOW_NETWORK=false
# When a created tool needs a non-stdlib import, file a human approve/deny request
# (dashboard + Telegram /approve /deny) instead of hard-failing.
ENABLE_DEP_APPROVAL=true
# Env-var names a created tool may read (comma-separated), exposed to its code as a
# dict SECRETS (the sandbox forbids `import os`, so this is the only way in).
# e.g. TOOL_SECRET_NAMES=SERVICE_EMAIL,SERVICE_PASSWORD  and then set those vars below.
TOOL_SECRET_NAMES=
# Trusted-tool tier: allow model-authored tools that need a RESTRICTED capability
# (os, sqlite3, open, subprocess, ...) to run OUTSIDE the sandbox, but only after a
# human reads the code and approves it in the dashboard. Off by default.
ENABLE_TRUSTED_TOOLS=false
# Cheap post-action verifier: after a turn that created/deleted/scheduled things,
# double-check the model actually finished (catches "deleted them all" after one).
ENABLE_ACTION_VERIFY=true
# Route each turn to think-on/think-off by prompt complexity (instant heuristics +
# a cheap classifier for the uncertain middle). Off by default.
ADAPTIVE_THINKING=false

# ============================================================================
# Skill creation (experimental; native mode only; safe — data, no code exec)
# ============================================================================
ENABLE_SKILL_CREATION=false

# ============================================================================
# Persona
# ============================================================================
# Self-persona editing: the agent can rewrite its own SOUL (voice only, not the
# operational system prompt) via update_soul. Previous persona is backed up.
ENABLE_SOUL_EDITING=true

# ============================================================================
# Built-in vetted tools (safe — first-class engine tools, not model-authored code)
# ============================================================================
ENABLE_DATASTORE=true
ENABLE_TABLES=true
ENABLE_ARTIFACTS=true
ENABLE_PDF=true
ENABLE_FILES=true
ENABLE_DOCUMENTS=true
ENABLE_KNOWLEDGE=true
ENABLE_WATCH=true
ENABLE_CHARTS=true
ENABLE_ASCII_CHARTS=true
ENABLE_ROUTINES=true

# ============================================================================
# Outbound notifications (owner-only: always reach the configured owner, never
# an arbitrary recipient) — email via SMTP and/or push via ntfy.
# ============================================================================
ENABLE_NOTIFY=true
# Owner's email address (where notifications are sent).
NOTIFY_EMAIL_TO=
# From address (defaults to SMTP_USER if left blank).
NOTIFY_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# ntfy.sh topic to publish to (owner subscribes on their phone). Treat the topic
# name itself as a secret — anyone who knows it can read the channel.
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh
# Background deliveries (scheduled results, watch alerts) ALSO fan out to these
# channels (comma-separated: "email,ntfy"). Telegram always gets them if enabled.
NOTIFY_FANOUT=

# ============================================================================
# Scheduler / clarify / observer
# ============================================================================
ENABLE_SCHEDULER=true
ENABLE_CLARIFY=true
ENABLE_OBSERVER=true
OBSERVER_REPEAT_THRESHOLD=2

# ============================================================================
# Memory (persistent facts about the user)
# ============================================================================
ENABLE_MEMORY=true
# auto | on | off — "auto" uses semantic (embedding-based) recall when an
# embedding endpoint is configured, else falls back to keyword recall.
SEMANTIC_RECALL=auto
# Embedding endpoint (OpenAI-compatible /embeddings). Leave blank for keyword-only
# memory recall. Can point at the same OpenRouter/OpenAI key or a local server.
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=
EMBEDDING_API_KEY=dummy
ENABLE_MEMORY_AUTOEXTRACT=true
# global: one shared memory bank keyed on MEMORY_USER_ID, so facts follow the
# person across every interface (dashboard, Telegram). session: legacy per-session
# isolation (e.g. a multi-user Telegram bot).
MEMORY_SCOPE=global
MEMORY_USER_ID=default

# ============================================================================
# Server
# ============================================================================
HOST=0.0.0.0
PORT=8700
# Where stdout/stderr is captured (the CLI redirects here); the dashboard's Logs
# page tails it. Relative paths resolve from the working directory.
LOG_FILE=argus.log

# Optional HTTPS: set BOTH to a PEM cert + key and the dashboard serves over TLS.
# Empty = plain HTTP (fine for a trusted LAN; see SECURITY.md for public exposure).
# Generate a self-signed cert with:
#   openssl req -x509 -newkey rsa:2048 -nodes -keyout argus-key.pem -out argus-cert.pem \
#     -days 825 -subj "/CN=argus"
SSL_CERTFILE=
SSL_KEYFILE=

# ============================================================================
# Telegram (optional; leave the token blank to run dashboard-only)
# ============================================================================
TELEGRAM_BOT_TOKEN=
# Comma-separated chat ids allowed to talk to the bot, e.g. 12345,67890
ALLOWED_CHAT_IDS=

# ============================================================================
# Admin / security
# ============================================================================
# Leave blank for an open local dashboard. Set a value to require an
# X-Admin-Token header on mutating/admin endpoints (config edit/save, restart,
# system-prompt edit, dependency/tool-trust approvals). Recommended for anything
# beyond localhost. See SECURITY.md.
ADMIN_TOKEN=
