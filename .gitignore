# ============================================================================
# SECRETS & CREDENTIALS — never commit these
# ============================================================================
.env
.env.local
# model connections + API keys
model_presets.json
# approved-code hashes
trusted_tools.json
dep_approvals.json

# ============================================================================
# RUNTIME STATE & USER DATA — per-install, not source
# ============================================================================
# memory.db, tables.db, knowledge.db, datastore.db, ...
*.db
memory/*.db
scheduled_jobs.json
watches.json
rules.json
approvals.json
permissions.json
custom_commands.yaml
# user-authored routines (repo-root runtime data dir only — not engine/routines/ source)
/routines/
# agent-created tools / skills
created_tools/
created_skills/
# agent file workspace + built web pages
workspace/
artifacts/

# Persona / prompt overrides (ship the defaults in code, not the user's edits)
SOUL.md
SOUL.md.bak
system_prompt.txt
system_prompt.md

# ============================================================================
# DEV / PERSONAL — not part of the shippable product (kept local, out of the public repo)
# ============================================================================
# personal deploy + research/probe scripts. `scripts/*` (not `scripts/`) so the
# skill-eval harness can be re-included — git cannot un-ignore a file whose
# parent DIRECTORY is excluded.
scripts/*
!scripts/skill_eval.py
!scripts/setup-sandbox.sh
docs/RUNBOOK.md
docs/routines-spec.md
docs/feature-backlog.md
docs/notes/
docs/findings-stresstest.md
docs/findings-toolcreation.md
docs/findings.md
docs/probe-battery.md
docs/plan-approval-gated-deps.md
docs/plan-trusted-tool-tier.md
docs/skill-candidates.md

# ============================================================================
# LOGS & TEMP
# ============================================================================
*.log
nohup.out
.argus.pid
.DS_Store
Thumbs.db

# ============================================================================
# PYTHON
# ============================================================================
.venv/
venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.ruff_cache/
build/
dist/

# ============================================================================
# NODE (only the Playwright QA harness uses this; not shipped)
# ============================================================================
node_modules/

# SDD design artifacts (internal, like docs/plan-*.md)
docs/superpowers/
.superpowers/

# A/B skill-validation: the batteries + their fixtures ship (they're the harness's
# input); the reports are local research output.
docs/ab/*
!docs/ab/batteries/
!docs/ab/fixtures/

# Local working notes for Claude (not part of the shippable product)
CLAUDE.md
